{
	"name": "camelai-docs",
	"private": true,
	"type": "module",
	"scripts": {
		"postinstall": "node scripts/prepare-open-mdx-docs.mjs",
		"dev": "node scripts/prepare-open-mdx-docs.mjs && open-mdx-docs dev",
		"build": "open-mdx-docs build",
		"start": "open-mdx-docs start",
		"deploy": "open-mdx-docs deploy",
		"ci:deploy": "wrangler deploy -c .open-mdx-docs/wrangler.json --keep-vars",
		"doctor": "open-mdx-docs doctor"
	},
	"devDependencies": {
		"open-mdx-docs": "github:Vercantez/open-mdx-docs",
		"wrangler": "4.112.0"
	},
	"overrides": {
		"@react-router/dev": "7.16.0",
		"react-router": "7.16.0"
	}
}
